{
  "$schema": "https://opencode.ai/config.json",
  "model": "Qwen3.6-27B-IQ4_XS-mtp.gguf",
  "autoupdate": true,
  "plugin": ["opencode-claude-auth@latest"],
  "enabled_providers": ["lmstudio", "llama.cpp", "anthropic"],
  "share": "disabled",
  "permission": {
      "*": "ask",
      "bash": {
        "*": "ask",
        "kubectl get *": "allow",
        "kubectl describe *": "allow",
        "kubectl logs *": "allow",
        "kubectl explain *": "allow",
        "kubectl top *": "allow",
        "kubectl version *": "allow",
        "kubectl cluster-info *": "allow",
        "kubectl api-resources *": "allow",
        "kubectl api-versions *": "allow",
        "gh pr list *": "allow",
        "gh pr view *": "allow",
        "gh pr status *": "allow",
        "gh pr checks *": "allow",
        "gh pr diff *": "allow",
        "gh pr comment list *": "allow",
        "gh workflow list *": "allow",
        "gh workflow view *": "allow",
        "gh release list *": "allow",
        "gh release view *": "allow",
        "gh repo view *": "allow",
        "aws eks describe *": "allow",
        "aws eks list *": "allow",
        "aws ec2 describe *": "allow",
        "aws s3 ls *": "allow",
        "aws iam list *": "allow",
        "aws iam get *": "allow",
        "aws cloudwatch get *": "allow",
        "aws sts get-caller-identity *": "allow",
        "flux get *": "allow",
        "flux logs *": "allow",
        "helm list *": "allow",
        "helm status *": "allow",
        "helm get *": "allow",
        "helm history *": "allow",
        "helm show *": "allow",
        "git log *": "allow",
        "git status *": "allow",
        "git diff *": "allow",
        "git show *": "allow",
        "docker ps *": "allow",
        "docker logs *": "allow",
        "ls *": "allow"
      },
      "edit": "ask",
      "glob": "allow",
      "grep": "allow",
      "read": {
        "*": "allow",
        "*.env": "deny",
        "*.env.*": "deny",
        "*.env.example": "allow",
        "*.env.default": "allow"
      },
      "playwright_browser_navigate": "allow",
      "playwright_browser_snapshot": "allow",
      "playwright_browser_take_screenshot": "allow",
      "playwright_browser_console_messages": "allow",
      "playwright_browser_network_requests": "allow",
      "playwright_browser_evaluate": "allow",
      "playwright_browser_hover": "allow",
      "playwright_browser_wait_for": "allow",
      "atlassian_atlassianUserInfo": "allow",
      "atlassian_getAccessibleAtlassianResources": "allow",
      "atlassian_getConfluencePage": "allow",
      "atlassian_searchConfluenceUsingCql": "allow",
      "atlassian_searchJiraIssuesUsingJql": "allow",
      "atlassian_getConfluenceSpaces": "allow",
      "atlassian_getPagesInConfluenceSpace": "allow",
      "atlassian_getConfluencePageFooterComments": "allow",
      "atlassian_getConfluencePageInlineComments": "allow",
      "atlassian_getConfluenceCommentChildren": "allow",
      "atlassian_getConfluencePageDescendants": "allow",
      "atlassian_getJiraIssue": "allow",
      "atlassian_getTransitionsForJiraIssue": "allow",
      "atlassian_getJiraIssueRemoteIssueLinks": "allow",
      "atlassian_getVisibleJiraProjects": "allow",
      "atlassian_getJiraProjectIssueTypesMetadata": "allow",
      "atlassian_getJiraIssueTypeMetaWithFields": "allow",
      "atlassian_getIssueLinkTypes": "allow",
      "atlassian_search": "allow",
      "atlassian_fetch": "allow",
      "atlassian_lookupJiraAccountId": "allow",
      "external_directory": {
        "*": "allow"
      },
      "webfetch": "allow",
      "websearch": "allow",
      "codesearch": "allow",
      "todowrite": "allow",
      "skill": "allow",
      "question": "allow"
  },
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "oauth": {},
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "provider": {
    "lmstudio": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio",
      "options": {
        "baseURL": "http://192.168.1.169:1234/v1",
        "apiKey": "lm-studio"
      },
      "models": {
        "qwen3.6-35b-a3b": {"name": "Qwen3.6 35B A3B UD", "modalities": {"input": ["text", "image"], "output": ["text"]}}
      },
      "whitelist": ["qwen3.6-35b-a3b"]
    },
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (local)",
      "options": {
        "baseURL": "http://172.30.48.1:8081/v1",
        "apiKey": "no-key"
      },
      "models": {
        "Qwen3.6-27B-IQ4_XS-mtp.gguf": {
          "name": "Qwen3.6 27B Dense MTP (IQ4_XS, 200K ctx)",
          "modalities": {"input": ["text"], "output": ["text"]}
        },
        "Qwen3.6-35B-A3B-MTP-IQ4_XS.gguf": {
          "name": "Qwen3.6 35B-A3B MoE (IQ4_XS, 262K ctx)",
          "modalities": {"input": ["text"], "output": ["text"]}
        },
        "gemma-4-26B-A4B-it-UD-Q4_K_XL.gguf": {
          "name": "Gemma 4 26B-A4B (Q4_K_XL, 262K ctx)",
          "modalities": {"input": ["text", "image"], "output": ["text"]}
        }
      },
      "whitelist": ["Qwen3.6-27B-IQ4_XS-mtp.gguf", "Qwen3.6-35B-A3B-MTP-IQ4_XS.gguf", "gemma-4-26B-A4B-it-UD-Q4_K_XL.gguf"]
    }
  }
}
