{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["opencode-claude-auth@latest"],
  "enabled_providers": ["lieselotte", "hermine", "anthropic", "openrouter"],
  "share": "disabled",
  "mcp": {
    "atlassian": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "oauth": {},
      "enabled": true
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    }
  },
  "provider": {
    "lieselotte": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (lieselotte)",
      "options": {
        "baseURL": "http://127.0.0.1:8081/v1",
        "apiKey": "no-key"
      },
      "models": {
        "Qwen3.6-27B": {
          "name": "Qwen3.6 27B Dense MTP",
          "modalities": {"input": ["text"], "output": ["text"]}
        },
        "Qwen3.6-35B-A3B": {
          "name": "Qwen3.6 35B-A3B MoE",
          "modalities": {"input": ["text"], "output": ["text"]}
        },
        "gemma-4-26B-A4B": {
          "name": "Gemma 4 26B-A4B",
          "modalities": {"input": ["text", "image"], "output": ["text"]}
        },
        "ornith-1.0-9b": {
          "name": "Ornith 1.0 9B Dense",
          "modalities": {"input": ["text"], "output": ["text"]}
        },
        "ornith-1.0-35b": {
          "name": "Ornith 1.0 35B MoE",
          "modalities": {"input": ["text"], "output": ["text"]}
        },
        "Qwen-AgentWorld-35B-A3B": {
          "name": "Qwen-AgentWorld 35B-A3B World Model",
          "modalities": {"input": ["text"], "output": ["text"]}
        },
        "gemma-4-31B": {
          "name": "Gemma 4 31B Dense QAT + MTP",
          "modalities": {"input": ["text", "image"], "output": ["text"]}
        }
      },
      "whitelist": ["Qwen3.6-27B", "Qwen3.6-35B-A3B", "gemma-4-26B-A4B", "ornith-1.0-9b", "ornith-1.0-35b", "Qwen-AgentWorld-35B-A3B", "gemma-4-31B"]
    },
    "hermine": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama.cpp (hermine)",
      "options": {
        "baseURL": "http://hermine:8081/v1",
        "apiKey": "no-key"
      },
      "models": {
        "Qwen3.6-27B": {
          "name": "Qwen3.6 27B Dense MTP",
          "modalities": {"input": ["text"], "output": ["text"]}
        },
        "gemma-4-31B": {
          "name": "Gemma 4 31B Dense QAT + MTP",
          "modalities": {"input": ["text", "image"], "output": ["text"]}
        }
      },
      "whitelist": ["Qwen3.6-27B", "gemma-4-31B"]
    },
    "openrouter": {
      "options": {
        "apiKey": "{env:OPENROUTER_API_KEY}"
      }
    },
    "elektronengehirn": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Elektronengehirn (stadt.werk)",
      "options": {
        "baseURL": "https://elektronengehirn.stadtwerk.org/v1",
        "apiKey": "{env:ELEKTRONENGEHIRN_API_KEY}"
      },
      "models": {
        "gemma-3-12b-it": {
          "name": "Gemma 3 12B IT",
          "modalities": { "input": ["text"], "output": ["text"] }
        }
      }
    }
  }
}
